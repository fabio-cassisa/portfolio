---
import { ClientRouter } from 'astro:transitions';
import '../styles/global.css';
import Navbar from '@components/Navbar.astro';
import Footer from '@components/Footer.astro';
import Terminal from '@components/Terminal.astro';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'dagas — creative technologist',
  description = 'designer, developer, and everything in between. portfolio of fabio cassisa.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <!-- fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:ital,wght@0,300;0,400;0,500;0,600;0,700;1,400&family=Inter:wght@400;500;600&display=swap"
      rel="stylesheet"
    />

    <!-- favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- meta -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0a0a0f" />
    <link rel="canonical" href={new URL(Astro.url.pathname, 'https://dagas-portfolio.vercel.app').href} />

    <!-- open graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="https://dagas-portfolio.vercel.app/og.png" />
    <meta property="og:url" content={new URL(Astro.url.pathname, 'https://dagas-portfolio.vercel.app').href} />
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content="https://dagas-portfolio.vercel.app/og.png" />

    <ClientRouter />
  </head>
  <body class="scanlines">
    <div class="mx-auto max-w-3xl px-6 py-8 md:py-16 pb-20">
      <Navbar />
      <main>
        <slot />
      </main>
      <Footer />
    </div>
    <Terminal />
  </body>
</html>
