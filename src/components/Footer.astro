---
import { info } from '@data/info';
---

<footer class="mt-20 pt-8 border-t border-[var(--color-border)]">
  <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 text-xs text-[var(--color-text-muted)]">
    <div class="flex items-center gap-4">
      {
        Object.entries(info.socialMedia).map(([name, url]) => (
          <a
            href={url}
            target="_blank"
            rel="noopener noreferrer"
            class="hover:text-[var(--color-accent)] transition-colors"
          >
            {name}
          </a>
        ))
      }
    </div>
    <p>
      <span class="text-[var(--color-accent)]">{info.name.toLowerCase()}</span> · 2024–{new Date().getFullYear()}
    </p>
  </div>
</footer>
