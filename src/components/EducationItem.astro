---
import type { Education } from '@data/info';

interface Props {
  item: Education;
}

const { item } = Astro.props;
---

<div class="py-3 border-b border-[var(--color-border)] last:border-b-0">
  <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-1">
    <div>
      <h3 class="text-sm font-semibold text-[var(--color-text-bright)]">
        {item.school}
      </h3>
      <p class="text-xs text-[var(--color-text)]">{item.degree}</p>
    </div>
    <span class="text-xs text-[var(--color-text-muted)] shrink-0">
      {item.start} — {item.end}
    </span>
  </div>
</div>
