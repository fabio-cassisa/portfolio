---
import type { Project } from '@data/info';

interface Props {
  project: Project;
}

const { project } = Astro.props;
const hasImage = project.thumbnail && project.thumbnail.length > 0;
const isPrivate = 'private' in project && project.private;
const linkUrl = project.live || project.github;
---

<article class="terminal-window group">
  {/* thumbnail or no-signal placeholder */}
  {linkUrl ? (
    <a
      href={linkUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="block overflow-hidden"
    >
      {hasImage ? (
        <img
          src={project.thumbnail}
          alt={project.title}
          width="800"
          height="192"
          class="w-full h-48 object-cover object-top transition-transform duration-500 group-hover:scale-105"
          loading="lazy"
        />
      ) : (
        <div class="no-signal h-48"></div>
      )}
    </a>
  ) : (
    <div class="block overflow-hidden">
      {hasImage ? (
        <img
          src={project.thumbnail}
          alt={project.title}
          width="800"
          height="192"
          class="w-full h-48 object-cover object-top transition-transform duration-500 group-hover:scale-105"
          loading="lazy"
        />
      ) : (
        <div class="no-signal h-48"></div>
      )}
    </div>
  )}

  {/* card body */}
  <div class="p-4">
    <div class="flex items-start justify-between gap-2 mb-2">
      <h3 class="text-sm font-semibold text-[var(--color-accent)] leading-tight">
        {project.title}
        {isPrivate && (
          <span class="text-[var(--color-text-muted)] font-normal text-xs ml-1">[private]</span>
        )}
      </h3>
      <div class="flex items-center gap-2 shrink-0">
        {project.github && (
          <a
            href={project.github}
            target="_blank"
            rel="noopener noreferrer"
            class="text-[var(--color-text-muted)] hover:text-[var(--color-accent)] transition-colors text-xs"
            aria-label={`GitHub repo for ${project.title}`}
          >
            src
          </a>
        )}
        {project.live && (
          <a
            href={project.live}
            target="_blank"
            rel="noopener noreferrer"
            class="text-[var(--color-text-muted)] hover:text-[var(--color-cyan)] transition-colors text-xs"
            aria-label={`Live demo for ${project.title}`}
          >
            live
          </a>
        )}
      </div>
    </div>
    <p class="text-xs text-[var(--color-text-muted)] mb-3 leading-relaxed">
      {project.description}
    </p>
    <div class="flex flex-wrap gap-1.5">
      {project.tech.map((t) => (
        <span class="tag">{t}</span>
      ))}
    </div>
  </div>
</article>
