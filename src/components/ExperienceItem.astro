---
import type { Experience } from '@data/info';

interface Props {
  item: Experience;
}

const { item } = Astro.props;
---

<div class="py-4 border-b border-[var(--color-border)] last:border-b-0">
  <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-1 mb-2">
    <div>
      <h3 class="text-sm font-semibold text-[var(--color-text-bright)]">
        {item.role}
        <span class="text-[var(--color-text-muted)] font-normal">
          @ {item.company}
        </span>
      </h3>
    </div>
    <span class="text-xs text-[var(--color-text-muted)] shrink-0">
      {item.start} — {item.end}
    </span>
  </div>
  <p class="text-xs text-[var(--color-cyan)] mb-2">{item.location}</p>
  <ul class="space-y-1">
    {
      item.description.map((line) => (
        <li class="text-xs text-[var(--color-text-muted)] pl-4 relative before:content-['–'] before:absolute before:left-0 before:text-[var(--color-border-bright)]">
          {line}
        </li>
      ))
    }
  </ul>
</div>
