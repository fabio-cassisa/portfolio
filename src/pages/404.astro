---
import Layout from '@layouts/Layout.astro';
---

<Layout title="404 — dagas" description="page not found.">
  <section class="flex flex-col items-center justify-center min-h-[60vh] text-center">
    <p class="text-xs text-[var(--color-text-muted)] mb-4">
      <span class="text-[var(--color-accent)]">$</span> cat {Astro.url.pathname}
    </p>
    <h1 class="text-6xl md:text-8xl font-bold text-[var(--color-accent)] mb-4">404</h1>
    <p class="text-sm text-[var(--color-text-muted)] mb-2">file not found. the void stares back.</p>
    <p class="text-xs text-[var(--color-text-muted)] mb-8">
      no such file or directory: <span class="text-[var(--color-red)]">{Astro.url.pathname}</span>
    </p>
    <a
      href="/"
      class="text-xs text-[var(--color-text-muted)] hover:text-[var(--color-accent)] transition-colors"
    >
      cd ~ →
    </a>
  </section>
</Layout>
